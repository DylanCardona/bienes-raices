extends ../layout/includes/header

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes Raices 
            span.font-normal SENA
        h2.text-center.text-2xl.font-extrabold=tituloPagina

        .mt-8.mx-auto.max-w-md 
            .bg-white.py-8.px-4.shadow.rounded-lg
                form.space-y-5(action="#", method="post")
                    div
                        label.block.text-sm.uppercase.text-gray-500.mb-3.font-bold(for="email") Email de Registro
                        input#email.w-full.px-3.py-2.border-gray-300.rounded-mb.placeholder-gray-400(placeholder="Escribe tu email")
                    div
                        label.block.text-sm.uppercase.text-gray-500.mb-3.font-bold(for="password") Contraseña
                        input#password.w-full.px-3.py-2.border-gray-300.rounded-mb.placeholder-gray-400(placeholder="Contraseña" type="password" name="password")
                    input(class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 cursor-pointer text-center rounded-lg" text="submit" value="Iniciar Sesión") 
                    .flex.items-center.justify-between.cl
                        a.text-gray-500.text-sm(href="/auth/register") ¿No tienes una cuenta? #[span.text-blue-300 Crea una]
                        a.text-gray-500.text-sm(href="#") Olvide contraseña